# Report Generate Agent — environment template
# Copy to .env and fill in. NEVER commit .env.

# --- Data source mode ---
# "email" (Gmail API) or "manual" (read Excel only)
DATA_SOURCE_MODE=email

# --- LLM (GreenNode AI Platform, OpenAI-compatible) ---
# Base URL is the GreenNode MAAS endpoint by default; override only if needed.
LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
# API key: create/get via the agentbase-llm skill, which writes LLM_API_KEY here:
#   bash greennode-agentbase-skills/.claude/skills/agentbase/scripts/aip.sh api-keys create --name report-agent-key
#   (or)  aip.sh api-keys get <name> --save-env
LLM_API_KEY=
# Model: use the model `path` from `aip.sh models get <uuid>` (not the code)
LLM_MODEL=
